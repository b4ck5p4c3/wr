# Copy this file to .env and fill it in. The binary reads each WR_ variable as
# the matching server option, and docker compose passes the file through.

# Server options.
WR_LISTEN_ADDRESS=http://0.0.0.0:8000
WR_DATABASE_URL=/data/wr.db
WR_WEB_ROOT_URL=https://your.ring

# Secrets. Outside dev mode at least one login provider and the session key are
# required, and the server refuses to start when they are missing. A session key
# is generated by `openssl rand -hex 32`.
WR_SESSION_KEY=
WR_GITHUB_CLIENT_ID=
WR_GITHUB_CLIENT_SECRET=
WR_TELEGRAM_BOT_TOKEN=
